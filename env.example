# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_CHAT_IDS=123456789,987654321  # Comma-separated Telegram user IDs allowed to control bot

# Polymarket / CLOB Credentials
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_passphrase
POLYMARKET_PRIVATE_KEY=your_wallet_private_key  # EVM wallet private key (0x...)
POLYMARKET_WALLET_ADDRESS=your_wallet_address

# Bot Settings (can also be changed via Telegram)
DEFAULT_STAKE_USDC=5.0          # Default stake per trade in USDC
MAX_STAKE_USDC=50.0             # Maximum allowed stake
MAX_OPEN_POSITIONS=5            # Max concurrent positions
COPY_TRADE_ENABLED=false        # Start with copy trading disabled
MIN_TRADER_WIN_RATE=0.60        # Min win rate to follow a trader (60%)
MIN_TRADER_TRADES=20            # Min number of trades for a trader to be considered
TOP_TRADERS_TO_TRACK=10         # Number of top traders to monitor

# Markets to watch (5min and 15min BTC/ETH up/down)
# These are fetched dynamically but you can pin specific market IDs
MARKET_REFRESH_INTERVAL=300     # Seconds between market list refresh

# Database
DATABASE_URL=sqlite+aiosqlite:///bot_data.db

# Logging
LOG_LEVEL=INFO
